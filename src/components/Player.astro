---
import playIcon from './icons/player-play.svg?raw';
import pauseIcon from './icons/player-pause.svg?raw';
import skipBackIcon from './icons/player-skip-back.svg?raw';
import skipForwardIcon from './icons/player-skip-forward.svg?raw';

declare global {
	interface Window {
		onSpotifyWebPlaybackSDKReady: () => void;
	}
}
---

<fglt-player>
	<div class="player">
		<p class="info">
			<span class="title Ellipsis"></span>
			<span class="artist Ellipsis"></span>
		</p>

		<img class="cover Backdrop Reflection" alt="" />

		<div
			class="progress"
			role="progressbar"
			aria-label="Elapsed time"
			aria-valuemin="0"
			aria-valuenow="0"
			aria-valuetext="0 seconds"
		>
		</div>

		<div class="controls">
			<button
				class="previous Button--icon"
				title="Previous track"
			>
				<Fragment set:html={skipBackIcon} />
			</button>

			<button class="playPause Button--icon">
				<span class="play">
					<span class="VisuallyHidden">Play</span>
					<Fragment set:html={playIcon} />
				</span>

				<span class="pause">
					<span class="VisuallyHidden">Pause</span>
					<Fragment set:html={pauseIcon} />
				</span>
			</button>

			<button class="next Button--icon" title="Next track">
				<Fragment set:html={skipForwardIcon} />
			</button>
		</div>
	</div>
</fglt-player>

<style>
	fglt-player {
		display: block;
		width: 100%;
		container-type: inline-size;
	}

	.player {
		display: grid;
		grid-template:
			'info controls'
			'progress controls' min-content
			/ 1fr auto;
		align-items: center;
		gap: 0.25lh 1ch;
		border-radius: var(--radius);
		padding: 0.5em 1ch;
		background: var(--color-surface-variant);
	}

	@container (min-width: 40ch) {
		.player {
			grid-template:
				'cover info controls'
				'cover progress controls' min-content
				/ auto 1fr auto;
		}
	}

	.info {
		grid-area: info;
		margin: 0;
		line-height: 1.2;
		font-size: var(--font-size-s);
	}

	.title {
		display: block;
	}

	.artist {
		color: var(--color-neutral);
		font-size: var(--font-size-s);
	}

	.cover {
		display: none;
		grid-area: cover;
		aspect-ratio: 1 / 1;
		height: 2lh;
	}

	@container (min-width: 40ch) {
		.cover {
			display: block;
		}
	}

	.controls {
		grid-area: controls;
		display: flex;
		justify-content: center;
		gap: 0 0.5ch;
	}

	.pause {
		display: none;
	}

	fglt-player[playing] .pause {
		display: revert;
	}

	fglt-player[playing] .play {
		display: none;
	}

	.next {
		grid-area: next;
	}

	.progress {
		--progress-ratio: 0%;
		grid-area: progress;
		border-radius: var(--radius-s);
		width: 100%;
		height: 0.25lh;
		background: linear-gradient(
			to right,
			var(--color-theme) 0%,
			var(--color-theme) calc(var(--progress-ratio) - 1px),
			var(--color-surface) calc(var(--progress-ratio))
		);
		transition: --progress-ratio 1s linear;
	}

	@property --progress-ratio {
		initial-value: 0%;
		inherits: false;
		syntax: '<percentage>';
	}
</style>

<script>
	export class Player extends HTMLElement {
		static observedAttributes = [
			'title',
			'artist',
			'cover',
			'duration',
			'elapsed',
			'playing'
		] as const;

		#title!: HTMLParagraphElement;
		#artist!: HTMLParagraphElement;
		#cover!: HTMLImageElement;
		#progress!: HTMLProgressElement;

		connectedCallback() {
			this.#title = document.querySelector('.title')!;
			this.#artist = document.querySelector('.artist')!;
			this.#cover = document.querySelector('.cover')!;
			this.#progress = document.querySelector('.progress')!;

			document
				.querySelector('.playPause')!
				.addEventListener('click', () => {
					this.dispatchEvent(
						new CustomEvent(
							this.getAttribute('playing') === null
								? 'play'
								: 'pause'
						)
					);
				});

			document
				.querySelector('.previous')!
				.addEventListener('click', () => {
					this.dispatchEvent(new CustomEvent('previous'));
				});

			document
				.querySelector('.next')!
				.addEventListener('click', () => {
					this.dispatchEvent(new CustomEvent('next'));
				});
		}

		attributeChangedCallback(
			name: (typeof Player.observedAttributes)[number],
			oldValue: string,
			value: string
		) {
			if (value === oldValue) {
				return;
			}

			switch (name) {
				case 'title':
					this.#title.innerText = value;
					break;

				case 'artist':
					this.#artist.innerText = `by ${value}`;
					break;

				case 'cover':
					this.#cover.src = value;
					break;

				case 'duration':
					this.#progress.setAttribute(
						'aria-valuemax',
						value
					);
					break;

				case 'elapsed':
					this.#progress.setAttribute(
						'aria-valuenow',
						value
					);

					this.#progress.setAttribute(
						'aria-valuetext',
						`${value} seconds`
					);

					const duration = Number(
						this.#progress.getAttribute('aria-valuemax')
					);

					this.#progress.style.setProperty(
						'--progress-ratio',
						`${(Number(value) / duration) * 100}%`
					);
					break;
			}
		}
	}

	customElements.define('fglt-player', Player);
</script>
