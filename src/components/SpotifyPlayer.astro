---
import Player from './Player.astro';

declare global {
	interface Window {
		onSpotifyWebPlaybackSDKReady: () => void;
	}
}
---

<fglt-spotify-player>
	<Player />
</fglt-spotify-player>

<script>
	import {
		spotifyApi,
		SpotifyCurrentDevice,
		spotifyTrackUri,
		type SpotifyId,
		type SpotifyPlaybackPlayer,
		type SpotifyPlaybackState
	} from '../services/spotify';

	export class SpotifyPlayer extends HTMLElement {
		#player = Promise.withResolvers<SpotifyPlaybackPlayer>();
		#api = spotifyApi();
		#ui!: HTMLElement;

		connectedCallback() {
			this.#ui = document.querySelector('fglt-player')!;

			this.#ui.addEventListener('previous', () => {
				this.#api.player.skipToPrevious(
					SpotifyCurrentDevice
				);

				this.#api.player.startResumePlayback(
					SpotifyCurrentDevice
				);
			});

			this.#ui.addEventListener('next', () => {
				this.#api.player.skipToNext(SpotifyCurrentDevice);
				this.#api.player.startResumePlayback(
					SpotifyCurrentDevice
				);
			});

			this.#ui.addEventListener('play', () => {
				this.#api.player.startResumePlayback(
					SpotifyCurrentDevice
				);
			});

			this.#ui.addEventListener('pause', () => {
				this.#api.player.pausePlayback(SpotifyCurrentDevice);
			});

			this.#loadDevice();
		}

		async loadPlaylist(
			trackIds: SpotifyId[],
			offset?: SpotifyId
		) {
			await this.#api.authenticate();
			await this.#player.promise;
			await this.#api.player.startResumePlayback(
				SpotifyCurrentDevice,
				undefined,
				trackIds.map(spotifyTrackUri),
				offset
					? {
							uri: spotifyTrackUri(offset)
						}
					: undefined
			);
		}

		async #loadDevice() {
			const token = await this.#api.getAccessToken();

			if (!token) {
				return;
			}

			window.onSpotifyWebPlaybackSDKReady = () => {
				const player = new window.Spotify.Player({
					name: 'Moodboard',
					getOAuthToken: (cb) => {
						this.#api
							.authenticate()
							.then(() => this.#api.getAccessToken())
							.then((token) => {
								cb(token?.access_token);
							});
					}
				});

				player.addListener('ready', ({device_id}) => {
					this.#api.player.transferPlayback(
						[device_id],
						false
					);
				});

				player.addListener(
					'initialization_error',
					({message}) => {
						console.error(message);
					}
				);

				player.addListener(
					'authentication_error',
					({message}) => {
						console.error(message);
					}
				);

				player.addListener('account_error', ({message}) => {
					console.error(message);
				});

				player.addListener(
					'player_state_changed',
					(state) => {
						this.#updateState(state);
					}
				);

				setInterval(() => {
					player.getCurrentState().then((state) => {
						if (state) {
							this.#updateState(state);
						}
					});
				}, 500);

				player.connect();
				this.#player.resolve(player);
			};

			const script = document.createElement('script');
			script.async = true;
			script.src = 'https://sdk.scdn.co/spotify-player.js';
			document.body.appendChild(script);
		}

		#updateState({
			duration,
			position,
			paused,
			track_window
		}: SpotifyPlaybackState) {
			this.#ui.setAttribute(
				'duration',
				`${Math.round(duration / 1000)}`
			);

			this.#ui.setAttribute(
				'elapsed',
				`${Math.round(position / 1000)}`
			);

			this.#ui.setAttribute(
				'title',
				track_window.current_track.name
			);

			this.#ui.setAttribute(
				'artist',
				track_window.current_track.artists.at(0)!.name
			);

			this.#ui.setAttribute(
				'cover',
				track_window.current_track.album.images.at(0)!.url
			);

			this.#ui.toggleAttribute('playing', !paused);
		}
	}

	customElements.define('fglt-spotify-player', SpotifyPlayer);
</script>
